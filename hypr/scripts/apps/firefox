#!/bin/bash

hyprctl dispatch "hl.dsp.exec_cmd('firefox', { workspace = '1 silent' })"
~/.config/hypr/scripts/wait_for -t 5 "select(.class | startswith(\"firefox\"))"
hyprctl dispatch "hl.dsp.window.move({ workspace = '1', window = 'class:^firefox.*$', follow = false })"

hyprctl eval '
    local function find_firefox(title_prefix)
        for _, w in ipairs(hl.get_windows()) do
            if w.class and w.title
                and w.class:sub(1, 7) == "firefox"
                and w.title:sub(1, #title_prefix) == title_prefix then
                return w
            end
        end
        return nil
    end

    local elapsed = 0
    local timeout = 2000
    local interval = 50

    local timer
    timer = hl.timer(function()
        elapsed = elapsed + interval
        if elapsed >= timeout then
            timer:set_enabled(false)
            return
        end

        local main      = find_firefox("[Main]")
        local secondary = find_firefox("[Secondary]")

        if main == nil then return end

        timer:set_enabled(false)

        -- Fix a weird bug by toggling twice the floating state
        if main ~= nil then
            hl.dispatch(hl.dsp.window.float({ action = "set",   window = main }))
            hl.dispatch(hl.dsp.window.float({ action = "unset", window = main }))
            hl.dispatch(hl.dsp.window.move({ workspace = "1",  window = main,      follow = false }))
        end
        if secondary ~= nil then
            hl.dispatch(hl.dsp.window.float({ action = "set",   window = secondary }))
            hl.dispatch(hl.dsp.window.float({ action = "unset", window = secondary }))
            hl.dispatch(hl.dsp.window.move({ workspace = "10", window = secondary, follow = false }))
        end
    end, { timeout = interval, type = "repeat" })
'
