{
    "label" : "lock",
    "action" : "loginctl lock-session",
    "text" : "Lock (l)",
    "keybind" : "l"
}
{
    "label" : "logout",
    "action" : "hyprshutdown",
    "text" : "Logout (q)",
    "keybind" : "q"
}
{
    "label" : "hibernate",
    "action" : "systemctl hibernate",
    "text" : "Hibernate (i)",
    "keybind" : "i"
}
{
    "label" : "shutdown",
    "action" : "hyprshutdown --post-cmd 'systemctl poweroff'",
    "text" : "Shutdown (h)",
    "keybind" : "h"
}
{
    "label" : "suspend",
    "action" : "systemctl suspend",
    "text" : "Suspend (s)",
    "keybind" : "s"
}
{
    "label" : "reboot",
    "action" : "hyprshutdown --post-cmd 'systemctl reboot'",
    "text" : "Reboot (r)",
    "keybind" : "r"
}
{
    "label" : "reboot-windows",
    "action" : "pkexec bootctl set-oneshot auto-windows && hyprshutdown --post-cmd 'systemctl reboot'",
    "text" : "Reboot toWindows (w)",
    "keybind" : "w",
    "circular": "true"
}
